# Copy to .env. App reads only from env — no passwords or hosts in code.

# PostgreSQL (required): either full URL…
# DATABASE_URL=postgres://user:secret@host:5432/dbname?sslmode=disable

# …or discrete vars (password only ever from POSTGRES_PASSWORD)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=moviedb
POSTGRES_SSLMODE=disable

# POSTGRES_MAX_CONNS=10

JWT_SECRET=your-secret
JWT_TTL_SECONDS=3600
# Refresh token TTL (default 7d if unset)
JWT_REFRESH_TTL_SECONDS=604800
PORT=8888
DYNAMODB_ENDPOINT=
AWS_REGION=us-east-1
